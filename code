import yfinance as yf
import pandas as pd
import numpy as np
import mplfinance as mpf

# Fetches historical data of the stock "APPL (APPLE)"
symbol = "APPL"
data = yf.download(symbol, period="3mo", interval="1d")

# Detects Bullish (price going up) Patterns
def detect_bullish_engulfing(df):
  patterns = []
  for i in range(1, len(df)):
    prev = df.iloc[i-1]
    curr = df.iloc[i]
    if (prev['Close'] < prev ['Open']) and (curr['Close'] > curr ['Open']):
      if (curr['Close'] > prev['Open']) and (curr['Open'] < prev['Close']):
        patterns.append(df.index[i])
  return patterns

# Detect Bearish (price going down) Patterns
def detect_bearish_engulfing(df):
  patterns = []
  for i in range (1, len(df)):
    prev = df.iloc[i-1]
    curr = df.iloc[i]
    if (prev['Close'] > prev['Open']) and (curr['Close'] < curr['Open']):
      if (curr['Open'] > prev['Close']) and (curr['Close'] < (prev['Open']):
        patterns.append(df.index[i])
  return patterns

# Scans for patterns
bullish_days = detect_bullish_engulfing(data)
bearish_days = detect_bearish_engulfing(data)

print ("Bullish Engulfing Days:", bullish_days)
print ("Bearish Engulfing Days:", bearish_days)

